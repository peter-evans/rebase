{
  "name": "rebase",
  "version": "1.0.0",
  "private": true,
  "description": "Rebase pull requests in a repository",
  "main": "lib/main.js",
  "scripts": {
    "clean": "rm -rf node_modules package-lock.json",
    "build-checkout": "npm install --prefix node_modules/checkout && npm run build --prefix node_modules/checkout",
    "build": "tsc && ncc build",
    "format": "prettier --write '**/*.ts'",
    "format-check": "prettier --check '**/*.ts'",
    "lint": "eslint src/**/*.ts",
    "test": "jest unit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peter-evans/rebase.git"
  },
  "keywords": [
    "actions",
    "pull",
    "rebase"
  ],
  "author": "Peter Evans",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/peter-evans/rebase/issues"
  },
  "homepage": "https://github.com/peter-evans/rebase",
  "dependencies": {
    "@actions/core": "1.4.0",
    "@actions/io": "1.1.1",
    "@octokit/graphql": "4.6.4",
    "checkout": "github:actions/checkout#v2.3.4",
    "uuid": "8.3.2"
  },
  "devDependencies": {
    "@types/jest": "26.0.24",
    "@types/node": "16.0.1",
    "@typescript-eslint/parser": "4.28.2",
    "@vercel/ncc": "0.28.6",
    "eslint": "7.30.0",
    "eslint-plugin-github": "4.1.3",
    "eslint-plugin-jest": "24.3.6",
    "jest": "27.0.6",
    "jest-circus": "27.0.6",
    "js-yaml": "4.1.0",
    "prettier": "2.3.2",
    "ts-jest": "27.0.3",
    "typescript": "4.3.5"
  }
}
